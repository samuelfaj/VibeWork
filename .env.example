# VibeWork Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control

# =============================================================================
# Process
# =============================================================================
# api | worker | all
PROCESS_MODE=api
NODE_ENV=development
SERVICE_NAME=vibework-backend
PORT=3000
# Run drizzle migrations on boot (entrypoint). Docker defaults to true.
RUN_MIGRATIONS=false

# =============================================================================
# MySQL Configuration
# =============================================================================
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DATABASE=vibe_db
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=your_secure_password_here

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGO_INITDB_DATABASE=vibe_notifications
MONGODB_URI=mongodb://localhost:27017/vibe_notifications

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Google Cloud Pub/Sub
# =============================================================================
PUBSUB_EMULATOR_HOST=localhost:8085
GCP_PROJECT_ID=local-dev
# Optional shared secret for POST /pubsub/push (required in production)
# PUBSUB_PUSH_TOKEN=

# =============================================================================
# Auth / CORS
# =============================================================================
FRONTEND_URL=http://localhost:5173
# Comma-separated list; defaults to FRONTEND_URL
CORS_ORIGINS=http://localhost:5173
BETTER_AUTH_SECRET=replace-with-long-random-secret
# ENABLE_SWAGGER=true
# ENABLE_SWAGGER=false

# =============================================================================
# Frontend (Vite)
# =============================================================================
VITE_API_URL=http://localhost:3000

# =============================================================================
# Required Ports
# =============================================================================
#   - 3306/3307 : MySQL
#   - 27017     : MongoDB
#   - 6379      : Redis
#   - 8085      : Pub/Sub Emulator
#   - 3000      : Backend
#   - 5173      : Frontend
