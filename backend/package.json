{
  "name": "@vibework/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./app": {
      "types": "./dist-types/src/app.d.ts",
      "import": "./src/app.ts",
      "default": "./src/app.ts"
    },
    "./types/app": {
      "types": "./dist-types/src/types/app.d.ts",
      "import": "./src/types/app.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "seed": "bun run seeders/index.ts",
    "seed:clean-reseed": "bun run seeders/clean-and-reseed.ts",
    "start": "bun run src/entrypoint.ts"
  },
  "dependencies": {
    "@vibe-code/contract": "workspace:*",
    "@aws-sdk/client-ses": "^3.1086.0",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@google-cloud/pubsub": "^5.3.1",
    "@node-rs/argon2": "^2.0.2",
    "@typegoose/typegoose": "^13.4.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "i18next": "^26.3.6",
    "ioredis": "^5.11.1",
    "mongoose": "^9.7.4",
    "mysql2": "^3.22.6",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "@types/node": "^22.15.21",
    "vitest": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@testcontainers/mysql": "^12.0.4",
    "@testcontainers/mongodb": "^12.0.4"
  }
}
