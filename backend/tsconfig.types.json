{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist-types",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "modules/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "**/integration.test.ts",
    "src/entrypoint.ts",
    "dist",
    "dist-types",
    "seeders",
    "tests"
  ]
}
