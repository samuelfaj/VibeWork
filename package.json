{
  "name": "vibe-code-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.8",
  "workspaces": [
    "backend",
    "frontend",
    "shared/*",
    "e2e/playwright"
  ],
  "scripts": {
    "prepare": "husky || true",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test:integration": "turbo run test:integration",
    "test:e2e": "bun run --filter @vibe/e2e-playwright test:e2e",
    "test:e2e:playwright": "bun run --filter @vibe/e2e-playwright test:e2e",
    "slice:new": "bun run scripts/slice-new.ts",
    "feature:map": "bun run scripts/generate-feature-map.ts",
    "feature:check": "bun run scripts/feature-check.ts",
    "feature:done": "bun run scripts/feature-done.ts",
    "banlist": "bun run scripts/banlist.ts",
    "i18n:parity": "bun run scripts/i18n-parity.ts",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.39.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.7",
    "turbo": "^2.10.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
